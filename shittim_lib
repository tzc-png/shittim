#!/bin/bash

# ==================== 1. 颜色配置 ====================
C_PREFIX_P="\033[0;90m"
C_PREFIX_A="\033[38;2;100;251;252m"
C_ALERT="\033[1;31m"
C_DEBUG="\033[1;35m"
NC="\033[0m"
C_CODE_DISPLAY="\033[1;32m"

# ==================== 2. 路径配置 ====================
SHITTIM_ROOT=$(
    cd "$(dirname "$0")"
    pwd
)
CONFIG_FILE="${SHITTIM_ROOT}/config/config"

# ---------- 默认值 ----------
silent=false
next_character=plana
is_exit=false
memory=10
model=qwen2.5:7b
voice=false
translate_model=translategemma:4b
venv=""
API_KEY=""
BASE_URL=""
MODEL_NAME=""
ENABLE_CHAT_API=true
ENABLE_TRANS_API=false

# ── Torch TTS 配置 ────────────────────────────────────────────────────────────
PLANA_ENGINE_DIR="${SHITTIM_ROOT}/voice/GPT-Sovits/plana_engine"
PLANA_GPT_PATH="${SHITTIM_ROOT}/voice/GPT-Sovits/models/Plana-e15.ckpt"
PLANA_VITS_PATH="${SHITTIM_ROOT}/voice/GPT-Sovits/models/Plana_e16_s208.pth"
PLANA_REF_WAV="${SHITTIM_ROOT}/voice/GPT-Sovits/models/ref.wav"
PLANA_REF_TXT="理解しました，先生は今，特にやるべきことはないですね，暇なんですね。"
PLANA_SERVER_SCRIPT="${SHITTIM_ROOT}/voice/GPT-Sovits/plana_tts_server.py"
PLANA_SOCK="/tmp/plana_tts.sock"
voice_tmp="${SHITTIM_ROOT}/voice/tmp/plana_tmp.wav"
# ─────────────────────────────────────────────────────────────────────────────

gpt_sovits_log_path="${SHITTIM_ROOT}/history/gpt_sovits.log"

if [ -f "${CONFIG_FILE}" ]; then
    source "${CONFIG_FILE}"
fi

if [ "$is_exit" = "true" ]; then
    exit 0
fi

CURRENT_PROFILE=$(powerprofilesctl get 2>/dev/null || echo "balanced")
if [ "$CURRENT_PROFILE" == "power-saver" ]; then
    if [ "$silent" == "system" ]; then silent=true; fi
else
    if [ "$silent" == "system" ]; then silent=false; fi
fi

# ==================== 3. 核心函数 ====================

msg() {
    local text="$1"
    local voice_file="$2"
    local is_alert="$3"

    local current_char=$next_character
    local prefix=""
    local voice_path=""

    if [ "$current_char" = "arona" ]; then
        prefix="${C_PREFIX_A}[Arona]${NC}"
        voice_path="${VOICE_BASE}/arona/${voice_file}"
        next_char_to_save="plana"
    else
        prefix="${C_PREFIX_P}[Plana]${NC}"
        voice_path="${VOICE_BASE}/plana/${voice_file}"
        next_char_to_save="arona"
    fi

    if [ "$current_char" = "plana" ]; then
        local display_color="${C_PREFIX_P}"
    else
        local display_color="${C_PREFIX_A}"
    fi

    if [ "$is_alert" = "true" ]; then
        display_color="${C_ALERT}"
    fi

    echo -e "${prefix} ${display_color}${text}${NC}"

    if [ "$voice_file" = "" ]; then
        sed -i "s/next_character=.*/next_character=\"$next_char_to_save\"/" "$CONFIG_FILE"
        next_character=$next_char_to_save
        return
    fi

    if [ "$silent" != "true" ] && [ -n "$voice_file" ]; then
        if [ -f "$voice_path" ]; then
            pkill -f "paplay.*${current_char}" >/dev/null 2>&1
            { paplay --client-name="${current_char}" "$voice_path" >/dev/null 2>&1; } &
        else
            echo -e "${C_DEBUG}[Debug] 找不到${current_char}的音频: ${voice_path}${NC}"
        fi
    fi

    sed -i "s/next_character=.*/next_character=\"$next_char_to_save\"/" "$CONFIG_FILE"
    next_character=$next_char_to_save
}

# ── TTS 服务管理 ──────────────────────────────────────────────────────────────

_ensure_tts_server() {
    if [ -S "$PLANA_SOCK" ] && pgrep -f "plana_tts_server.py" >/dev/null 2>&1; then
        return 0
    fi
    echo -e "${C_DEBUG}[TTS] 正在启动语音引擎...${NC}" >&2
    mkdir -p "$(dirname "$voice_tmp")"
    PLANA_ENGINE_DIR="$PLANA_ENGINE_DIR" \
    PLANA_GPT_PATH="$PLANA_GPT_PATH" \
    PLANA_VITS_PATH="$PLANA_VITS_PATH" \
    PLANA_REF_WAV="$PLANA_REF_WAV" \
    PLANA_REF_TXT="$PLANA_REF_TXT" \
    PLANA_SOCK="$PLANA_SOCK" \
        nohup ${venv}/bin/python "$PLANA_SERVER_SCRIPT" >>"$gpt_sovits_log_path" 2>&1 &

    local waited=0
    until [ -S "$PLANA_SOCK" ]; do
        sleep 1
        waited=$((waited + 1))
        if [ $waited -ge 60 ]; then
            echo -e "${C_DEBUG}[Error] 语音引擎启动超时${NC}" >&2
            return 1
        fi
    done
    sleep 1
    echo -e "${C_DEBUG}[TTS] 语音引擎就绪${NC}" >&2
}

onnx_tts() {
    local text="$1"
    local out_wav="$2"
    _ensure_tts_server || return 1
    local req
    
    #req=$(printf '{"text":"%s","out":"%s","lang":"ja"}\n' \
    #    "$(echo "$text" | sed 's/"/\\"/g')" "$out_wav")

    req=$(jq -n --arg text "$text" --arg out "$out_wav" \
        '{"text":$text,"out":$out,"lang":"ja"}')
    req="${req}"$'\n'

    local response
    response=$(echo "$req" | nc -U "$PLANA_SOCK" 2>/dev/null)
    if echo "$response" | grep -q 'status.*ok'; then
        return 0
    else
        echo -e "${C_DEBUG}[Error] TTS 服务返回错误：${response}${NC}" >&2
        return 1
    fi
}

# ── can_use_api ───────────────────────────────────────────────────────────────
can_use_api() {
    [ -n "$API_KEY" ] && [ -n "$BASE_URL" ] && [ -n "$MODEL_NAME" ]
}

# ── 历史记录（messages JSON 格式）────────────────────────────────────────────
HISTORY_FILE="${SHITTIM_ROOT}/history/plana_history.jsonl"

# 追加一条记录
append_history() {
    local role="$1"     # user 或 assistant
    local content="$2"
    local time_str="$3"
    local emotion="$4"

    mkdir -p "$(dirname "$HISTORY_FILE")"

    # 记录带时间戳
    if [ "$role" = "user" ]; then
        printf '{"role":"user","content":%s,"time":"%s"}\n' \
            "$(echo "$content" | jq -Rs .)" "$time_str" >> "$HISTORY_FILE"
    else
        [ -z "$emotion" ] && emotion="neutral"

        printf '{"role":"assistant","content":%s,"time":"%s","emotion":"%s"}\n' \
            "$(echo "$content" | jq -Rs .)" "$time_str" "$emotion" >> "$HISTORY_FILE"
    fi
}

# 读取最近 N 轮对话，组装成 messages JSON 数组（不含 system）
# 返回值：JSON 字符串，如 [{"role":"user","content":"...","emotion":"..."},...]
get_history_messages() {
    local n="$1"   # 保留最近 n 轮（1轮=1user+1assistant）
    local lines=$((n * 2))

    if [ ! -s "$HISTORY_FILE" ]; then
        echo "[]"
        return
    fi

    # 【修改】：不再强行丢弃 emotion 字段，而是允许它存在于导出的 JSON 数组中
    tail -n "$lines" "$HISTORY_FILE" \
        | jq -s '[.[] | {role: .role, content: .content, emotion: .emotion}]'
}

# 场景重置判定（复用原逻辑，改为读 jsonl 最后一条时间）
context_auto_reset_check() {
    if [ ! -s "$HISTORY_FILE" ]; then
        return 0  # 无历史，不需要插入重置提示
    fi

    local last_time
    last_time=$(tail -n 10 "$HISTORY_FILE" \
        | grep '"role":"user"' | tail -n 1 \
        | grep -oP '\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}' | tail -n 1)

    [ -z "$last_time" ] && return 0

    local last_seconds now_seconds diff
    last_seconds=$(date -d "$last_time" +%s)
    now_seconds=$(date +%s)
    diff=$((now_seconds - last_seconds))

    if [ $diff -gt 1800 ]; then
        local hour period
        hour=$(date +%H)
        period="深夜"
        [ $hour -ge 5 ]  && [ $hour -lt 11 ] && period="早晨"
        [ $hour -ge 11 ] && [ $hour -lt 14 ] && period="中午"
        [ $hour -ge 14 ] && [ $hour -lt 18 ] && period="下午"
        [ $hour -ge 18 ] && [ $hour -lt 24 ] && period="晚上"
        echo "一段时间过去了，现在是${period}，之前的场景已结束，请根据当前时间重新开始互动。"
    fi
}

# ==================== 4. 启动检查 ====================
if [ "$1" = "plana" ] && [ "$SHITTIM" = true ]; then
    if [ "$voice" = "true" ]; then
        if [ ! -f "$PLANA_GPT_PATH" ]; then
            echo -e "${C_DEBUG}[Warning] 未找到 GPT 模型：${PLANA_GPT_PATH}${NC}"
        fi
        if [ ! -f "$PLANA_VITS_PATH" ]; then
            echo -e "${C_DEBUG}[Warning] 未找到 SoVITS 模型：${PLANA_VITS_PATH}${NC}"
        fi
        if [ ! -f "$PLANA_SERVER_SCRIPT" ]; then
            echo -e "${C_DEBUG}[Warning] 未找到推理服务脚本：${PLANA_SERVER_SCRIPT}${NC}"
        fi
    fi
fi
