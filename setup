#!/bin/bash

# ====================================================
# Shittim Box Setup Protocol - 什亭之匣配置协议
# ====================================================

safe_backup() {
    local target_file=$1
    local bak_file="${target_file}.bak"

    if [ -f "$target_file" ]; then
        if [ -s "$bak_file" ]; then
            echo "\n\033[1;33m[警告]\033[0m 备份文件 $bak_file 已存在且包含数据。"
            echo "\033[0;90m--- 当前备份内容 (.bak) ---\033[0m"
            tail -n 8 "$bak_file"
            echo "\033[0;90m---------------------------\033[0m"
            echo "\033[1;32m--- 即将存入的内容 (Current) ---\033[0m"
            tail -n 8 "$target_file"
            echo "\033[1;32m-------------------------------\033[0m"

            printf "\033[1;36m是否覆盖旧的备份文件？(y/n): \033[0m"
            # 兼容各种 Shell 的 read 写法
            read confirm

            # 使用标准的 [ ] 语法进行字符串比较
            if [ "$confirm" = "n" ] || [ "$confirm" = "N" ]; then
                printf "\033[0;90m[Plana]\033[0m 已取消覆盖。当前数据未备份。\n"
                return 1
            elif [ "$confirm" = "y" ] || [ "$confirm" = "Y" ]; then
                mv "$target_file" "$bak_file"
                return 0
            else
                echo "unexpected"
                exit 1
            fi
        fi
    fi
}

# 1. 环境准备
SHITTIM_DIR=$(
    cd "$(dirname "$0")"
    pwd
)
BASHRC="$HOME/.bashrc"
BACKUP_BASHRC="$HOME/.bashrc.shittim.bak"

echo "\033[0;90m[Plana]\033[0m 正在启动配置协议，目标目录: ${SHITTIM_DIR}"

# 2. 备份原始文件
cp "$BASHRC" "$BACKUP_BASHRC"
echo "\033[0;90m[Plana]\033[0m 已备份原始 .bashrc 至 ${BACKUP_BASHRC}"

# 3. 历史记录归档
HISTORY_LOG="${SHITTIM_DIR}/history/plana_history.log"
if safe_backup "$HISTORY_LOG"; then
    echo "\033[0;90m[Plana]\033[0m 记忆数据归档成功。"
fi
mkdir -p "${SHITTIM_DIR}/history"
touch "$HISTORY_LOG"

SECURITY_LOG="${SHITTIM_DIR}/history/security.log"
if safe_backup "$SECURITY_LOG"; then
    echo "\033[0;90m[Plana]\033[0m 安全日志归档成功。"
fi
touch "$SECURITY_LOG"

# 4. 配置文件强刷
CONFIG_FILE="${SHITTIM_DIR}/config/config"
mkdir -p "${SHITTIM_DIR}/config"
if safe_backup "$CONFIG_FILE"; then
    echo "\033[0;90m[Plana]\033[0m 配置文件已备份。"
fi

cat <<EOF >"$CONFIG_FILE"
silent=false
is_exit=false
characteristic=standard
next_character="plana"
cmd=secure
cmd_ignore=true
memory=recent
model=qwen2.5:7b
EOF

# 5. 配置～/.bashrc
sed -i '/# >>> SHITTIM BOX CONFIG START >>>/,/# <<< SHITTIM BOX CONFIG END <<</d' "$BASHRC"
# 在配置块内重新定义 color_prompt，以覆盖文件前部的 unset 操作
cat <<EOF >>"$BASHRC"

# >>> SHITTIM BOX CONFIG START >>>
# 什亭之匣沉浸式视觉与功能配置区

# 强制开启颜色支持探测 (防止被前文 unset 影响)
case "\$TERM" in
    xterm-color|*-256color) local_color_prompt=yes;;
esac

# 终端配色增强 (TrueColor)
if [ "\$local_color_prompt" = yes ]; then
    # 普拉娜粉与阿罗娜蓝配色方案
    PS1='\${debian_chroot:+(\$debian_chroot)}\[\033[38;2;255;139;193m\]\u@\h\[\033[00m\]:\[\033[38;2;186;249;254m\]\w\[\033[00m\]\$ '
else
    PS1='\${debian_chroot:+(\$debian_chroot)}\u@\h:\w\$ '
fi
unset local_color_prompt

# 路径与自动唤醒协议
export PATH="${SHITTIM_DIR}:\$PATH"
if [ -f "${SHITTIM_DIR}/shittim_welcome" ]; then
    "${SHITTIM_DIR}/shittim_welcome"
fi
# <<< SHITTIM BOX CONFIG END <<<
EOF

# 6. 设置权限
chmod +x "${SHITTIM_DIR}/shittim"*

echo "\033[0;90m[Plana]\033[0m 配置同步成功 老师，请执行 \033[1;32msource ~/.bashrc\033[0m 以激活协议。"
