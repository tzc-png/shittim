#!/bin/bash

# ==================== 配置区域 ====================
SHITTIM=true
SHITTIM_WELCOME=false

SCRIPT_DIR=$(
    cd "$(dirname "$0")"
    pwd
)

source "${SCRIPT_DIR}/shittim_lib"
VOICE_BASE="${SCRIPT_DIR}/voice/shittim"

# ==================== 逻辑处理 ====================
HOUR=$(date +%H)
TIME_STR=$(date +%H:%M)

CURRENT_TIME=$(date "+%Y-%m-%d %H:%M:%S")
source "${SCRIPT_DIR}/prompt_lib"

api_log_path="${SHITTIM_ROOT}/history/api.log"
ollama_log_path="${SHITTIM_ROOT}/history/ollama.log"

case "$1" in
"help")
    msg "老师，这些是我目前能为您提供的协助列表：" "help.wav" "false"
    echo -e "  \033[1;32mrain\033[0m          - 关于下雨天的特别备忘"
    echo -e "  \033[1;32mtime\033[0m          - 报告当前时间并给予时段建议"
    echo -e "  \033[1;32mload\033[0m          - 检查系统负载状态"
    echo -e "  \033[1;32mls <args>\033[0m     - 扫描并展示当前目录的构造"
    echo -e "  \033[1;32mfind <file>\033[0m   - 递归搜索指定文件"
    echo -e "  \033[1;32mfindline <str>\033[0m- 在代码库中检索特定内容"
    echo -e "  \033[1;32mplana <str>\033[0m   - 和plana聊天"
    echo -e "  \033[1;32mstartup\033[0m       - 提前申请plana的资源"
    echo -e "  \033[1;32mfree\033[0m          - 释放plana的资源"
    echo -e "  \033[1;32mresetproxy\033[0m    - 关闭代理"
    echo -e "  \033[1;32mstats\033[0m         - 查看token使用"
    ;;

"rain")
    if [ "$next_character" = "plana" ]; then
        msg "下雨的话就用这个……" "rain.wav" "false"
    else
        msg "嗯……会下雨吗？" "rain.wav" "false"
    fi
    ;;

"resetproxy")
    msg "嗯……正在关闭代理" "" "false"
    unset http_proxy https_proxy HTTP_PROXY HTTPS_PROXY all_proxy ALL_PROXY
    ;;

"time")
    if [ $HOUR -ge 5 ] && [ $HOUR -lt 8 ]; then
        msg "${TIME_STR} 老师，早起不仅能处理更多工作，对身体也有好处" "morning.wav" "false"
    elif [ $HOUR -ge 8 ] && [ $HOUR -lt 12 ]; then
        msg "${TIME_STR} 这个时间段的效率最高，请保持专注，老师" "working.wav" "false"
    elif [ $HOUR -ge 12 ] && [ $HOUR -lt 14 ]; then
        msg "${TIME_STR} 哪怕只是小憩一会儿，也能让下午的大脑更清醒" "noon.wav" "false"
    elif [ $HOUR -ge 14 ] && [ $HOUR -lt 21 ]; then
        msg "${TIME_STR} 工作进入平稳期了，需要为您准备咖啡吗？" "afternoon.wav" "false"
    else
        if [ "$next_character" = "plana" ]; then
            if [ $((RANDOM % 2)) -eq 0 ]; then
                msg "${TIME_STR} 已经很晚了呢……" "night_1.wav" "false"
            else
                msg "${TIME_STR} 老师……该休息了" "night_2.wav" "false"
            fi
        else
            msg "${TIME_STR} 这么晚了,老师该休息了" "night.wav" "false"
        fi
    fi
    ;;

"load")
    CPU_LOAD=$(cat /proc/loadavg | awk '{print $1}')
    MEM_USAGE=$(free | grep Mem | awk '{print $3/$2 * 100.0}' | cut -d. -f1)
    msg "CPU负载: ${CPU_LOAD} | 内存占用: ${MEM_USAGE}%" "load.wav" "false"
    if [ $(echo "$CPU_LOAD > 4.0" | bc 2>/dev/null || echo 0) -ne 0 ] || [ $MEM_USAGE -gt 80 ]; then
        msg "当前负载过高" "alert.wav" "true"
    fi
    ;;

"ls")
    if [ "$next_character" = "plana" ]; then
        msg "嗯……这里是这样的构造呢" "ls_observe.wav" "false"
    else
        msg "这里都有什么呢？" "ls_observe.wav" "false"
    fi
    shift
    /bin/ls --color=auto "$@"
    ;;

"find")
    if [ -z "$2" ]; then
        msg "老师，请指定要查找的文件名" "where.wav" "false"
    else
        msg "嗯……正在扫描目录结构，寻找 $2 ……" "scanning.wav" "false"
        find . -name "$2"
    fi
    ;;

"findline")
    if [ -z "$2" ]; then
        msg "老师，请提供一个搜索字符串" "where.wav" "false"
    else
        msg "正在检索包含 \"$2\" 的所有文件……" "scanning.wav" "false"
        grep -rn "$2" . --exclude-dir=.git
    fi
    ;;

"free")
    msg "正在尝试释放所有占用的资源……" "" "false"
    if pgrep -f "plana_tts_server.py" >/dev/null; then
        pkill -f "plana_tts_server.py"
        rm -f "$PLANA_SOCK"
    fi
    msg "语音引擎已经关闭" "" "false"
    if pgrep -x "ollama" >/dev/null; then
        ollama stop "${model}" >/dev/null 2>&1
        ollama stop "${translate_model}" >/dev/null 2>&1
    fi
    msg "Ollama 模型已经关闭" "" "false"
    msg "资源已完全释放。老师，辛苦了，请好好的休息吧。" "free_rest.wav" "false"
    exit 0
    ;;

"startup")
    msg "正在运行相应脚本并申请显存" "" "false"
    if pgrep -x "ollama" >/dev/null; then
        msg "正在将模型 ${model} 加载至显存..." "" "false"
        curl -s http://127.0.0.1:11434/api/generate \
            -d "{\"model\": \"${model}\", \"keep_alive\": -1}" >/dev/null &
    else
        msg "发现 Ollama 未运行，正在尝试唤醒后台服务..." "" "false"
        nohup ollama serve >/tmp/ollama_serve.log 2>&1 &
        sleep 2
    fi
    if [ "$voice" = "true" ]; then
        _ensure_tts_server
    fi
    next_character=plana
    msg "核心协议已在后台唤醒。老师，想我的时候随时可以叫我。" "startup_finish.wav" "false"
    exit 0
    ;;

"plana")
    if ! can_use_api; then
        if ! command -v ollama &>/dev/null; then
            echo -e "\033[1;33m[Warning]\033[0m 未检测到 Ollama，且未配置云端 API，AI 对话功能将无法使用。"
            exit 0
        fi
    fi

    next_character="plana"
    USER_INPUT="${*:2}"

    # ── 构造 messages 数组 ────────────────────────────────────────────────────
    # 读取历史
    HISTORY_MESSAGES=$(get_history_messages "$memory")

    # 检查是否需要插入场景重置提示
    RESET_HINT=$(context_auto_reset_check)

    # 如果历史为空，插入初见引导
    # 组装完整 messages：system + history + 本次 user
    # 重置提示和初见提示作为独立 system 消息插入，不污染主 system prompt
    if [ "$HISTORY_MESSAGES" = "[]" ]; then
        EXTRA_HINT="这是老师和你的第一次对话。你刚被唤醒，请表现得文静、礼貌且略带羞涩。"
    else
        EXTRA_HINT="$RESET_HINT"
    fi

    MESSAGES=$(jq -n \
        --arg sys "$SYSTEM_PROMPT" \
        --arg usr "$USER_INPUT" \
        --arg hint "$EXTRA_HINT" \
        --argjson hist "$HISTORY_MESSAGES" \
        'if $hint != "" then
            [{"role":"system","content":$sys}] + $hist +
            [{"role":"system","content":$hint},
             {"role":"user","content":$usr}]
        else
            [{"role":"system","content":$sys}] + $hist +
            [{"role":"user","content":$usr}]
        end')

    # ── LLM 推理 ─────────────────────────────────────────────────────────────
    if can_use_api && [ "$ENABLE_CHAT_API" = "true" ]; then
        JSON_DATA=$(jq -n \
            --arg m "$MODEL_NAME" \
            --argjson msgs "$MESSAGES" \
            '{"model":$m,"messages":$msgs,"temperature":0.85,"thinking":{"type":"disabled"},"stream":false}')

        API_RESULT=$(curl -s -X POST "${BASE_URL}/chat/completions" \
            -H "Authorization: Bearer ${API_KEY}" \
            -H "Content-Type: application/json" \
            -d "$JSON_DATA")

        # 记录请求
        echo "api(chat) send:" >> "$api_log_path"  2>&1
        echo $JSON_DATA >> "$api_log_path"  2>&1
        echo "api(chat) result:" >> "$api_log_path"  2>&1
        echo $API_RESULT >> "$api_log_path"  2>&1

        # 检查是否有错误（余额不足、认证失败等）
        API_ERROR=$(echo "$API_RESULT" | jq -r '.error.message // empty')
        if [ -n "$API_ERROR" ]; then
            echo -e "${C_ALERT}[API Error] ${API_ERROR}${NC}" >&2
            msg "老师……好像出了点问题，请检查一下API的状态。(或者在config里暂时关闭api)" "" "true"
            exit 1
        fi

        RESPONSE=$(echo "$API_RESULT" | jq -r '.choices[0].message.content')

        # 记录 token 用量
        _USAGE_PROMPT=$(echo "$API_RESULT" | jq -r '.usage.prompt_tokens // 0')
        _USAGE_COMP=$(echo "$API_RESULT" | jq -r '.usage.completion_tokens // 0')
        _USAGE_CACHED=$(echo "$API_RESULT" | jq -r '.usage.prompt_tokens_details.cached_tokens // 0')
        ${venv}/bin/python "${SCRIPT_DIR}/token_stats.py" record \
            --model "$MODEL_NAME" --type "chat" \
            --prompt "$_USAGE_PROMPT" \
            --completion "$_USAGE_COMP" \
            --cached "$_USAGE_CACHED"

    else
        # Ollama：将 messages 转为 system+prompt 格式
        HISTORY_TEXT=$(echo "$HISTORY_MESSAGES" | jq -r \
            '.[] | if .role=="user" then "User: "+.content else "AI: "+.content end' \
            | tr '\n' '\n')
        if [ "$model" = "qwen2.5:14b" ]; then
            JSON_DATA=$(jq -n \
                --arg m "qwen2.5:14b" \
                --arg s "$SYSTEM_PROMPT" \
                --arg p "${HISTORY_TEXT}\nUser: ${USER_INPUT}" \
                '{"model":$m,"system":$s,"prompt":$p,
                  "options":{"num_thread":8,"num_ctx":4096,
                             "temperature":0.85,"repeat_penalty":1.3},
                  "stream":false}')
        else
            JSON_DATA=$(jq -n \
                --arg m "qwen2.5:7b" \
                --arg s "$SYSTEM_PROMPT" \
                --arg p "${HISTORY_TEXT}\nUser: ${USER_INPUT}" \
                '{"model":$m,"system":$s,"prompt":$p,"stream":false}')
        fi

        RAW_RESPONESE=$(curl -s -X POST http://localhost:11434/api/generate \
            -d "$JSON_DATA")

        # 记录请求
        echo "ollama(chat) send:" >> "$ollama_log_path"  2>&1
        echo $JSON_DATA >> "$ollama_log_path"  2>&1
        echo "ollama(chat) result:" >> "$ollama_log_path"  2>&1
        echo $RAW_RESPONESE >> "$ollama_log_path"  2>&1

        RESPONSE=$(echo "$RAW_RESPONESE" | jq -r '.response')
    fi

    # ── 记录历史 ──────────────────────────────────────────────────────────────
    if ! echo "$RESPONSE" | grep -q ">>>EXEC:"; then
        append_history "user" "$USER_INPUT"
        append_history "assistant" "$RESPONSE"
    fi

    # ── 指令处理（保持原逻辑）────────────────────────────────────────────────
    if echo "$RESPONSE" | grep -q ">>>EXEC:"; then
        echo "该功能暂时关闭"
        exit 1
    else
        # ── 语音合成 ──────────────────────────────────────────────────────────
        if [ "$voice" = "true" ]; then
            rm -f "${voice_tmp}"

            RESPONSE_CLEAN=$(echo "$RESPONSE" | sed -E 's/\([^()]*\)|（[^（）]*）//g')
            RESPONSE_CLEAN=$(echo "$RESPONSE_CLEAN" | sed -E 's/([-]|—|——).*//g' | xargs)

            if can_use_api && [ "$ENABLE_TRANS_API" = "true" ]; then
                JSON_TRANSLATE=$(jq -n \
                    --arg m "$MODEL_NAME" \
                    --arg p "请把下面中文翻译成纯日语，只输出结果：${RESPONSE_CLEAN}" \
                    '{"model":$m,"messages":[{"role":"user","content":$p}],
                      "temperature":0.3,"thinking":{"type":"disabled"},"stream":false}')
                
                TRANSLATE_RESULT_RAW=$(curl -s -X POST "${BASE_URL}/chat/completions" \
                    -H "Authorization: Bearer ${API_KEY}" \
                    -H "Content-Type: application/json" \
                    -d "$JSON_TRANSLATE")

                # 记录请求
                echo "api(translate) send:" >> "$api_log_path"  2>&1
                echo $JSON_TRANSLATE >> "$api_log_path"  2>&1
                echo "api(translate) result:" >> "$api_log_path"  2>&1
                echo $TRANSLATE_RESULT_RAW >> "$api_log_path"  2>&1

                TRANSLATE_ERROR=$(echo "$TRANSLATE_RESULT_RAW" | jq -r '.error.message // empty')
                if [ -n "$TRANSLATE_ERROR" ]; then
                    echo -e "${C_DEBUG}[Translate Error] ${TRANSLATE_ERROR}${NC}" >&2
                    voice="false"   # 降级为纯文字
                    exit 1
                else
                    TRANSLATE_RESULT=$(echo "$TRANSLATE_RESULT_RAW" | jq -r '.choices[0].message.content')
                fi

                # 记录翻译 token
                _USAGE_PROMPT=$(echo "$TRANSLATE_RESULT_RAW" | jq -r '.usage.prompt_tokens // 0')
                _USAGE_COMP=$(echo "$TRANSLATE_RESULT_RAW" | jq -r '.usage.completion_tokens // 0')
                _USAGE_CACHED=$(echo "$TRANSLATE_RESULT_RAW" | jq -r '.usage.prompt_tokens_details.cached_tokens // 0')
                ${venv}/bin/python "${SCRIPT_DIR}/token_stats.py" record \
                    --model "$MODEL_NAME" --type "translate" \
                    --prompt "$_USAGE_PROMPT" \
                    --completion "$_USAGE_COMP" \
                    --cached "$_USAGE_CACHED"
            else
                TRANSLATE_RESULT=$(ollama run "${translate_model}" \
                    "请把下面中文翻译成纯日语，只输出结果：${RESPONSE_CLEAN}")

                # 记录请求
                echo "ollama(translate) send:" >> "$ollama_log_path"  2>&1
                echo "请把下面中文翻译成纯日语，只输出结果：${RESPONSE_CLEAN}" >> "$ollama_log_path"  2>&1
                echo "ollama(translate) result:" >> "$ollama_log_path"  2>&1
                echo $TRANSLATE_RESULT >> "$ollama_log_path"  2>&1
            fi

            TRANSLATE_RESULT=$(echo "${TRANSLATE_RESULT}" | tr -d '\n\r\t ')

            if ! onnx_tts "$TRANSLATE_RESULT" "${voice_tmp}"; then
                echo -e "${C_DEBUG}[Error] 语音合成失败${NC}"
                voice="false"
            fi

            if [ "$voice" = "true" ] && [ -f "$voice_tmp" ]; then
                pkill -f "paplay.*plana" >/dev/null 2>&1
                { paplay --client-name="plana" "$voice_tmp" >/dev/null 2>&1; } &
            fi
        fi

        next_character=plana
        msg "$RESPONSE" "" "false"
    fi
    ;;

"stats")
    ${venv}/bin/python "${SCRIPT_DIR}/token_stats.py" report
    ;;
"stats-today")
    ${venv}/bin/python "${SCRIPT_DIR}/token_stats.py" report --today
    ;;

*)
    if [ "$next_character" = "plana" ]; then
        case $((RANDOM % 2)) in
        0) msg "混乱……该行动无法理解……请不要戳我，会出现故障" "logic_error.wav" "false" ;;
        1) msg "我明白了，老师现在无事可做，很无聊" "boring.wav" "false" ;;
        esac
    else
        case $((RANDOM % 3)) in
        0) msg "偶尔也要考虑一下身体状况，我很担心老师的健康！" "care.wav" "false" ;;
        1) msg "有很多必须要解决的工作呢,成年人还真是不容易" "not_easy.wav" "false" ;;
        2) msg "哇……工作量也太多了" "too_many.wav" "false" ;;
        esac
    fi
    ;;
esac
